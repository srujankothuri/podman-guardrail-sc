# Ollama — local model server
OLLAMA_BASE_URL=http://localhost:11434
GUARDIAN_MODEL=hf.co/ibm-granite/granite-guardian-3.3-8b-GGUF
LLM_MODEL=granite3.3:2b

# Redis
REDIS_URL=redis://localhost:6379

# Storage
CHROMA_PERSIST_DIR=./chroma_db
POLICIES_DIR=./policies
LOGS_DIR=./logs

# Rate limiting
RATE_LIMIT_PER_MIN=10
RATE_LIMIT_BURST=3
MAX_QUEUED_JOBS=2

# Timeouts (seconds)
GG_TIMEOUT=20
LLM_TIMEOUT=120
RETRIEVAL_TIMEOUT=5
